# ====================================
# Confession Wall - Environment Variables
# ====================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ------------------
# Supabase Configuration
# ------------------
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (SERVER-SIDE ONLY — never expose to client!)
# Used for admin operations that bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------
# Gemini AI Configuration
# ------------------
# Get your API key from Google AI Studio:
# https://aistudio.google.com/apikey
# Used for content moderation (profanity, hate speech, toxicity filtering)
GEMINI_API_KEY=your-gemini-api-key-here

# ------------------
# Cloudflare Turnstile Configuration
# ------------------
# Get your site key and secret key from Cloudflare Dashboard:
# https://dash.cloudflare.com/?to=/:account/turnstile
# Used for anti-spam CAPTCHA verification on forms
# Free tier: unlimited requests

# Site key (public, safe for client-side)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Secret key (SERVER-SIDE ONLY — never expose to client!)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ------------------
# VAPID Keys for Web Push Notifications
# ------------------
# Generate VAPID keys using: npx web-push generate-vapid-keys
# These are required for Web Push Notification functionality

# Public key (safe for client-side, used in PushManager.subscribe)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Private key (SERVER-SIDE ONLY — used to sign push messages)
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# Contact email for VAPID (used as subject)
VAPID_SUBJECT=mailto:admin@example.com
